{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "username", "email"]
    },
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "recipientId": { "type": "string" },
        "roomId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "replyTo": { "type": "object" },
        "voice": { "type": "string" },
        "image": { "type": "string" },
        "reactions": { "type": "object" }
      },
      "required": ["senderId", "text", "timestamp"]
    },
    "Room": {
      "title": "Room",
      "description": "A chat room or group",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["private", "group"] },
        "pinnedMessages": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["members", "type"]
    },
    "Call": {
      "title": "Call",
      "description": "A voice or video call session",
      "type": "object",
      "properties": {
        "callerId": { "type": "string" },
        "callerName": { "type": "string" },
        "recipientId": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "video"] },
        "status": { "type": "string", "enum": ["ringing", "ongoing", "rejected", "ended"] },
        "offer": { "type": "object" },
        "answer": { "type": "object" }
      },
      "required": ["callerId", "recipientId", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/rooms/{roomId}": {
      "schema": "Room",
      "description": "Chat rooms"
    },
    "/calls/{userId}": {
      "schema": "Call",
      "description": "Call sessions"
    }
  }
}
